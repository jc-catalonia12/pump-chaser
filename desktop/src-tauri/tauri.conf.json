{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MEXC Trading Bot",
  "version": "0.1.7",
  "identifier": "com.mexc.tradingbot",
  "build": {
    "frontendDist": "../../web",
    "devUrl": "http://127.0.0.1:8001"
  },
  "app": {
    "windows": [
      {
        "label": "splash",
        "title": "MEXC Trading Bot",
        "width": 440,
        "height": 320,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "url": "splash.html",
        "devtools": false
      },
      {
        "label": "main",
        "title": "MEXC Trading Bot",
        "width": 1320,
        "height": 900,
        "visible": false,
        "url": "about:blank",
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "TAURI_UPDATER_PUBKEY_PLACEHOLDER",
      "endpoints": [
        "https://github.com/OWNER/mexc-trading-bot-rust/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../config/**/*",
      "../../web/**/*",
      "../../desktop/icon.png",
      "../../release-assets/models/**/*",
      "../../release-assets/data/**/*",
      "../../release-assets/seed.manifest"
    ],
    "category": "Finance",
    "shortDescription": "MEXC perpetual futures trading bot",
    "longDescription": "MEXC USDT-M futures scanner, risk engine, paper/live trading, and ML-assisted signals.",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
